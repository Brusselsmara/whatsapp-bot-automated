{
  "rewrites": [
    { "source": "/pay/:code", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/(index.html|styles.css|app.js|manifest.webmanifest)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    }
  ],
  "functions": {
    "api/whatsapp.js":              { "maxDuration": 30 },
    "api/app.js":                   { "maxDuration": 30 },
    "api/outbound-ip.js":           { "maxDuration": 15 },
    "api/yellowcard-webhook.js":    { "maxDuration": 30 },
    "api/poll-topups.js":           { "maxDuration": 60 },
    "api/poll-transactions.js":     { "maxDuration": 60 },
    "api/receipt.js":               { "maxDuration": 15 },
    "api/fee-schedule.js":          { "maxDuration": 15 },
    "api/admin-kyc-decision.js":    { "maxDuration": 15 },
    "api/admin-kyc-request-info.js":{ "maxDuration": 10 },
    "api/admin.js":                 { "maxDuration": 30 }
  }
}