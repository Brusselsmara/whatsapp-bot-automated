# ============================================================
# Copy this file to ".env.local" for local testing with
# `vercel dev`. In production, add EVERY one of these in:
# Vercel Dashboard -> your project -> Settings -> Environment Variables
# ============================================================

# --- Twilio (WhatsApp) ---
# Get these from https://console.twilio.com  (Account Info panel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The WhatsApp-enabled Twilio number, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+1XXXXXXXXXX

# --- Supabase ---
# Get these from https://app.supabase.com -> your project -> Settings -> API
SUPABASE_URL=
# Use the SERVICE ROLE key (not the anon key) since this runs server-side only.
# Never expose this key in any frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# --- Yellow Card ---
# Get these from your Yellow Card dashboard once your integration is approved:
# https://docs.yellowcard.engineering
YELLOWCARD_API_KEY=
YELLOWCARD_SECRET_KEY=
# Sandbox first, then swap to the production URL Yellow Card gives you.
YELLOWCARD_BASE_URL=https://sandbox.api.yellowcard.io

# --- Resend (for KYC review emails with Approve/Reject links) ---
# Get your key from https://resend.com/api-keys
RESEND_API_KEY=
# While testing, you can send from Resend's shared test address without
# verifying your own domain: onboarding@resend.dev
RESEND_FROM_EMAIL=PayLink <onboarding@resend.dev>
# Your own email — this is where KYC review emails get sent
ADMIN_EMAIL=

# --- Invoice payments (Workflow 4 — Pay Invoice) ---
# FX rate margin for live invoice quotes: displayRate = ycRate × (FX_RATE_MULTIPLIER_BASE − fx_margin_pct)
FX_RATE_MULTIPLIER_BASE=1.75
QUOTE_LOCK_MINUTES=10
# Yellow Card POBO flat fee in USD (converted at YC sell rate before quote is shown)
POBO_FLAT_FEE_USD=25
# Yellow Card POBO percentage on invoice face value
POBO_FEE_PCT=0.25
# PayLink profit markup percentage on invoice face value
INVOICE_PROFIT_MARKUP_PCT=1

# --- Send money (Workflow 3 — domestic + cross-border fee model) ---
# Domestic sends (same currency in/out): markup on top of Yellow Card's own
# send fee — same formula for bank and momo, in whatever currency the send
# itself is in (numbers are NOT converted per-currency):
#   amount <= threshold -> flat DOMESTIC_FEE_FLAT_AMOUNT
#   amount >  threshold -> flat amount + PCT × (amount − threshold)
DOMESTIC_FEE_FLAT_AMOUNT=5
DOMESTIC_FEE_FLAT_THRESHOLD=500
DOMESTIC_FEE_PCT_ABOVE_THRESHOLD=0.01
# Cross-border sends (different currency in/out): flat markup on YC's send fee
# (fee is looked up and paid in the SENDER's home currency, not converted)
CROSSBORDER_FEE_MARKUP_PCT=0.15
# FX margin shaved off the bridged (via-USD) rate, in PayLink's favour.
# Also reused by cross-currency invoice payments (Workflow 4) when the
# invoice's currency differs from the payer's home-currency wallet — same
# bridging math, just solved for the wallet (source) amount instead of the
# recipient (destination) amount.
CROSSBORDER_FX_MARGIN_PCT=0.02
# Reduced VIP FX margin for business accounts sending BWP -> ZAR (South Africa)
# above the threshold amount below
CROSSBORDER_VIP_FX_MARGIN_PCT=0.01
CROSSBORDER_VIP_MIN_AMOUNT_BWP=500000

# --- Top-up balance (Workflow 2) ---
# Markup on Yellow Card's collection/receive fee (default 10%). Deducted from
# wallet credit when the top-up completes successfully.
TOPUP_FEE_MARKUP_PCT=0.10

# --- App ---
# The public HTTPS URL Vercel gives your deployment (root only — no trailing
# slash, and NOT the /api/whatsapp webhook path). A trailing slash is tolerated
# but will be normalised. Example:
#   https://your-app.vercel.app
PUBLIC_APP_URL=

# A long random secret shared with your cron trigger (e.g. cron-job.org).
# Protects /api/poll-topups from being called by randoms. Generate one with:
#   openssl rand -hex 32
# See README "Set up a cron trigger" section for how this is used.
CRON_SECRET=

# Set to "production" so Twilio webhook signature verification is
# enforced. Vercel sets NODE_ENV=production automatically for deployed builds.
# Yellow Card webhook signatures are ALWAYS enforced when YELLOWCARD_SECRET_KEY is set.
# NODE_ENV=production
