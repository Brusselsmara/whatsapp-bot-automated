# ============================================================
# Copy this file to ".env.local" for local testing with
# `vercel dev`. In production, add EVERY one of these in:
# Vercel Dashboard -> your project -> Settings -> Environment Variables
# ============================================================

# --- Meta WhatsApp Cloud API ---
# Create an app at https://developers.facebook.com → Add WhatsApp product.
# Use a System User permanent token with whatsapp_business_messaging permissions.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional — useful for support / debugging
WHATSAPP_BUSINESS_ACCOUNT_ID=
# App → Settings → Basic → App Secret (webhook signature verification)
WHATSAPP_APP_SECRET=
# Any random string you choose — must match Meta webhook "Verify token"
# Generate in PowerShell: -join ((1..32 | ForEach-Object { '{0:x2}' -f (Get-Random -Maximum 256) }))
WHATSAPP_VERIFY_TOKEN=
# Graph API version (default v21.0)
# WHATSAPP_GRAPH_VERSION=v21.0

# --- Supabase ---
# Get these from https://app.supabase.com -> your project -> Settings -> API
SUPABASE_URL=
# Use the SERVICE ROLE key (not the anon key) since this runs server-side only.
# Never expose this key in any frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# --- Yellow Card ---
# Get these from your Yellow Card dashboard once your integration is approved:
# https://docs.yellowcard.engineering
YELLOWCARD_API_KEY=
YELLOWCARD_SECRET_KEY=
# Sandbox first, then swap to the production URL Yellow Card gives you.
YELLOWCARD_BASE_URL=https://sandbox.api.yellowcard.io
# Set to "true" only when intentionally using a production YELLOWCARD_BASE_URL.
# Without this, production URLs are ignored and sandbox is used instead.
# YELLOWCARD_ALLOW_PRODUCTION=

# --- Resend (for KYC review emails with Approve/Reject links) ---
# Get your key from https://resend.com/api-keys
RESEND_API_KEY=
# While testing, you can send from Resend's shared test address without
# verifying your own domain: onboarding@resend.dev
RESEND_FROM_EMAIL=PayLink <onboarding@resend.dev>
# Your own email — this is where KYC review emails get sent
ADMIN_EMAIL=

# Password for the PayLink admin dashboard at /api/admin (operators only).
# Generate with: openssl rand -hex 32
# Required in production — customers never see this URL or password.
ADMIN_SECRET=

# --- PayLink service fees (Workflows 3 & 4 — sends + invoice payments) ---
# Tiered BWP flat fee + 1.5× Yellow Card disbursement fee (see lib/fees.js).
# Customer pays: flat tier fee + YC disbursement fee + 0.5× YC fee markup.
PAYLINK_YC_FEE_MULTIPLIER=1.5
# Outbound quote display: displayRate = ycRate × (FX_RATE_MULTIPLIER_BASE − fx_margin_pct)
FX_RATE_MULTIPLIER_BASE=1.75
QUOTE_LOCK_MINUTES=10
# FX margin shaved off the bridged (via-USD) rate, in PayLink's favour.
# Also reused by cross-currency invoice payments (Workflow 4) when the
# invoice's currency differs from the payer's home-currency wallet — same
# bridging math, just solved for the wallet (source) amount instead of the
# recipient (destination) amount.
CROSSBORDER_FX_MARGIN_PCT=0.02
# Reduced VIP FX margin for business accounts sending BWP -> ZAR (South Africa)
# above the threshold amount below
CROSSBORDER_VIP_FX_MARGIN_PCT=0.01
CROSSBORDER_VIP_MIN_AMOUNT_BWP=500000

# --- Top-up balance (Workflow 2) ---
# BWP 10 flat + 1.2× Yellow Card collection fee (deducted from wallet credit on completion).
TOPUP_FLAT_FEE_BWP=10
TOPUP_YC_FEE_MULTIPLIER=1.2

# --- App ---
# The public HTTPS URL Vercel gives your deployment (root only — no trailing
# slash, and NOT the /api/whatsapp webhook path). A trailing slash is tolerated
# but will be normalised. Example:
#   https://your-app.vercel.app
PUBLIC_APP_URL=

# A long random secret shared with your cron trigger (e.g. cron-job.org).
# Protects /api/poll-transactions from being called by randoms. Generate one with:
#   openssl rand -hex 32
# One cron job polls pending top-ups, sends, invoice payments, and delivers PDF receipts.
# Required in production — /api/poll-transactions returns 401 without it.
CRON_SECRET=

# HMAC secret for signed PDF receipt URLs (/api/receipt?id=&sig=).
# Recommended in production. Falls back to CRON_SECRET if unset.
# Generate with: openssl rand -hex 32
RECEIPT_SIGNING_SECRET=

# --- Observability (optional) ---
# Sentry DSN for production error alerts. Leave empty for console-only logging.
SENTRY_DSN=

# Set to "production" so Meta webhook signature verification is
# enforced. Vercel sets NODE_ENV=production automatically for deployed builds.
# Yellow Card webhook signatures are ALWAYS enforced when YELLOWCARD_SECRET_KEY is set.
# NODE_ENV=production
